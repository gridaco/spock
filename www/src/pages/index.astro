---
import Check from '@lucide/astro/icons/check';
import Copy from '@lucide/astro/icons/copy';
import ExperienceTrace from '../components/marketing/experience-trace.astro';
import FrameworkStructure from '../components/marketing/framework-structure.astro';
import SpaceShader from '../components/marketing/space-shader.astro';
import SpockCode from '../components/marketing/spock-code.astro';
import MarketingLayout from '../layouts/marketing-layout.astro';

const title = 'Spock Programming Language';
const description =
  'Define backend rules and interface states in explicit text, check them as one project, and run a working product prototype.';
const humanCommand = 'npm i -g spock';
const agentCommand = 'npx skills add gridaco/spock';

const authorityCode = [
  'auth table user {',
  '  key id: uuid = auto',
  '  username: text unique',
  '  full_name: text?',
  '  private: bool = false',
  '  joined_at: timestamp = now',
  '}',
].join('\n');

const frameworkLayers = [
  {
    label: 'framework',
    title: 'One project',
    copy: 'Check the authority backend and Uhura client, then serve Studio, Editor, and Play together.',
  },
  {
    label: 'backend',
    title: 'Spock language',
    copy: 'Model backend data, relationships, constraints, defaults, and operations.',
  },
  {
    label: 'experience',
    title: 'Uhura language',
    copy: 'Model UI-session state, experience transitions, and presentation.',
  },
];

const roles = [
  {
    title: 'Make decisions while they are cheap',
    copy: 'Exercise data shapes, constraints, storage, and refusal paths before implementation choices harden.',
  },
  {
    title: 'Give agents a bounded world',
    copy: 'Explicit contracts name the types, operations, outcomes, and states production work must preserve.',
  },
  {
    title: 'Start production with answers',
    copy: 'Choose the real stack after the team has exercised the product end to end—not while its rules are still guesses.',
  },
];
---

<MarketingLayout title={title} description={description}>
  <main id="content">
    <section class="bg-canvas" aria-labelledby="hero-title">
      <div
        class="mx-auto grid max-w-[1280px] border-x border-line lg:min-h-[700px] lg:grid-cols-[0.9fr_1.1fr]"
      >
        <div
          class="flex flex-col justify-center px-6 py-16 sm:px-10 sm:py-20 lg:px-16 lg:py-22"
          data-hero-audience
          data-active-audience="humans"
        >
          <h1
            id="hero-title"
            class="max-w-[680px] font-sans text-[clamp(3.2rem,5.2vw,5.4rem)] font-medium leading-[0.92] tracking-[-0.065em] text-ink"
          >
            The logical product compiler.
          </h1>

          <div class="hero-audience-tabs mt-8" role="tablist" aria-label="Choose an audience">
            <button
              id="hero-tab-humans"
              class="hero-audience-tab"
              type="button"
              role="tab"
              aria-selected="true"
              aria-controls="hero-command-humans hero-copy-humans"
              data-audience-tab="humans"
            >
              For humans
            </button>
            <span class="hero-audience-divider" aria-hidden="true"></span>
            <button
              id="hero-tab-agents"
              class="hero-audience-tab"
              type="button"
              role="tab"
              aria-selected="false"
              aria-controls="hero-command-agents hero-copy-agents"
              tabindex="-1"
              data-audience-tab="agents"
            >
              For agents
            </button>
          </div>

          <div class="hero-actions mt-5">
            <div class="hero-command" role="group" aria-label="Spock setup command">
              <span class="select-none text-code-muted">$</span>
              <code
                id="hero-command-humans"
                role="tabpanel"
                aria-labelledby="hero-tab-humans"
                data-audience-command="humans"
                data-command={humanCommand}
              >
                {humanCommand}
              </code>
              <code
                id="hero-command-agents"
                role="tabpanel"
                aria-labelledby="hero-tab-agents"
                data-audience-command="agents"
                data-command={agentCommand}
                hidden
              >
                {agentCommand}
              </code>
              <button
                class="hero-copy-button"
                type="button"
                data-copy-command={humanCommand}
                aria-label="Copy setup command"
              >
                <Copy class="copy-icon copy-icon-default" size={16} stroke-width={1.75} />
                <Check class="copy-icon copy-icon-success" size={16} stroke-width={2} />
              </button>
              <span class="sr-only" data-copy-status aria-live="polite"></span>
            </div>

            <a
              class="inline-flex min-h-12 items-center justify-center rounded-md bg-ink px-5 text-sm font-semibold text-white outline-none transition-colors hover:bg-code-line focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-canvas"
              href="/docs/"
            >
              Read the docs
            </a>
          </div>

          <div class="hero-audience-copy">
            <p
              id="hero-copy-humans"
              data-audience-copy="humans"
              aria-labelledby="hero-tab-humans"
              aria-hidden="false"
            >
              Spock is a programming language that gives the whole team one
              source of truth. Check product rules and interface behavior
              together, then run a prototype that can say no.
            </p>
            <p
              id="hero-copy-agents"
              data-audience-copy="agents"
              aria-labelledby="hero-tab-agents"
              aria-hidden="true"
            >
              Spock is a programming language that makes product intent
              explicit. Give agents backend rules and interface states as one
              bounded project to check and run—not a scattered stack to
              reconstruct.
            </p>
          </div>
        </div>

        <div
          class="marketing-grid celestial-field flex min-w-0 flex-col justify-center border-t border-line bg-paper px-5 py-12 sm:px-10 sm:py-16 lg:border-l lg:border-t-0 lg:px-12"
        >
          <SpaceShader />
          <FrameworkStructure />
        </div>
      </div>
    </section>

    <section class="bg-paper" aria-label="Framework responsibility layers">
      <div class="mx-auto grid max-w-[1280px] border-x border-t border-line md:grid-cols-3">
        {
          frameworkLayers.map((layer, index) => (
            <article
              class:list={[
                'px-6 py-6 sm:px-8',
                index < frameworkLayers.length - 1 &&
                  'border-b border-line md:border-b-0 md:border-r',
              ]}
            >
              <p class="font-mono text-[0.62rem] tracking-[0.05em] text-faint">{layer.label}</p>
              <h2 class="mt-2 text-base font-semibold tracking-[-0.02em] text-ink">{layer.title}</h2>
              <p class="mt-1 text-sm leading-6 text-muted">{layer.copy}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="bg-canvas" aria-labelledby="authority-title">
      <div class="mx-auto max-w-[1280px] border-x border-t border-line px-6 py-20 sm:px-10 sm:py-24 lg:px-16 lg:py-28">
        <div
          class="grid gap-8 lg:grid-cols-[minmax(0,1.35fr)_minmax(18rem,0.65fr)] lg:items-end"
        >
          <div>
            <p
              class="mb-5 font-mono text-[0.68rem] font-semibold tracking-[0.08em] text-accent"
            >
              the product contract
            </p>
            <h2
              id="authority-title"
              class="max-w-[48rem] font-sans text-[clamp(2.65rem,4.3vw,4.25rem)] font-medium leading-[1.04] tracking-[-0.04em] text-ink"
            >
              The product should only have to say it once.
            </h2>
          </div>
          <p class="max-w-xl text-base leading-7 text-muted lg:justify-self-end">
            Spock keeps durable product truth—data, constraints, defaults, and
            operations—in one compact authority model. People and agents work
            from the same explicit text, with structured diagnostics when the
            contract does not hold.
          </p>
        </div>

        <div class="mt-14 grid overflow-hidden rounded-xl border border-line bg-paper lg:grid-cols-2">
          <article class="flex min-w-0 flex-col border-b border-line p-6 sm:p-8 lg:border-b-0 lg:border-r lg:p-10">
            <p class="font-mono text-[0.63rem] tracking-[0.05em] text-accent">spock language</p>
            <h3 class="mt-4 max-w-lg text-3xl font-medium tracking-[-0.045em] text-ink">
              Write the rule beside the data it governs.
            </h3>
            <p class="mt-4 max-w-lg text-base leading-7 text-muted">
              Define tables, relationships, defaults, value constraints, and
              operation signatures close enough to reason about together. The
              compiler turns that source into a contract that runtimes and
              tools can inspect.
            </p>
            <SpockCode
              code={authorityCode}
              label="backend/app.spock"
              meta="authority"
              class="mt-8 w-full"
            />
          </article>

          <article class="flex min-w-0 flex-col p-6 sm:p-8 lg:p-10">
            <p class="font-mono text-[0.63rem] tracking-[0.05em] text-moss">spock studio</p>
            <h3 class="mt-4 max-w-lg text-3xl font-medium tracking-[-0.045em] text-ink">
              Run the contract. Inspect the result.
            </h3>
            <p class="mt-4 max-w-lg text-base leading-7 text-muted">
              Studio reads the active compiled contract. Browse and filter
              rows, insert valid data, run functions, inspect storage when
              enabled, and compare actor-sensitive outcomes—without building a
              separate prototype console.
            </p>
            <figure class="product-shot mt-8">
              <img
                src="/images/spock-studio.webp"
                alt="Spock Studio showing the post table and the generated form for adding a row from the compiled contract."
                width="3670"
                height="2396"
                loading="lazy"
              />
            </figure>
          </article>
        </div>
      </div>
    </section>

    <section class="night-sky text-white" aria-labelledby="uhura-title">
      <SpaceShader stars />
      <div class="mx-auto max-w-[1280px] border-x border-white/15 px-6 py-20 sm:px-10 sm:py-24 lg:px-16 lg:py-28">
        <div class="grid gap-8 lg:grid-cols-[1fr_0.72fr] lg:items-end">
          <div>
            <p
              class="mb-5 font-mono text-[0.68rem] font-semibold tracking-[0.08em] text-[#ffab63]"
            >
              the experience contract
            </p>
            <h2
              id="uhura-title"
              class="max-w-4xl font-sans text-[clamp(3rem,6vw,6rem)] font-medium leading-[0.92] tracking-[-0.07em]"
            >
              Design the outcome, not just the screen.
            </h2>
          </div>
          <p class="max-w-xl text-lg leading-8 text-white/68 lg:justify-self-end">
            Uhura models UI-session state and transitions. Author the loading,
            empty, optimistic, confirmed, and refused examples the product
            needs. The checker validates them; Editor presents the previews
            together before the production UI is built.
          </p>
        </div>

        <figure class="uhura-shot mt-14">
          <div class="uhura-editor-shell">
            <aside class="uhura-editor-sidebar" aria-hidden="true">
              <div class="uhura-editor-sidebar-head">
                <span>uhura editor</span>
              </div>

              <div class="uhura-editor-search">
                <svg viewBox="0 0 20 20" aria-hidden="true">
                  <circle cx="8.5" cy="8.5" r="4.75"></circle>
                  <path d="m12 12 4 4"></path>
                </svg>
                <span>search previews</span>
              </div>

              <div class="uhura-editor-items">
                <span>feed</span>
                <span class="is-active">post</span>
                <span>profile</span>
                <span>followers</span>
              </div>
            </aside>

            <div class="uhura-editor-canvas">
              <img
                src="/images/uhura-editor.webp"
                alt="Uhura Editor canvas showing checked Instagram page states, transitions, and preview provenance."
                width="3042"
                height="2358"
                loading="lazy"
              />
            </div>
          </div>
        </figure>

        <div class="mt-18 grid gap-8 border-t border-white/15 pt-14 lg:grid-cols-[0.68fr_1.32fr] lg:gap-14">
          <div>
            <p class="font-mono text-[0.63rem] tracking-[0.05em] text-[#ffab63]">one action, end to end</p>
            <h3 class="mt-4 text-3xl font-medium tracking-[-0.045em] sm:text-4xl">
              Optimistic first. Durable truth still wins.
            </h3>
            <p class="mt-5 max-w-xl text-base leading-8 text-white/65">
              Follow one action from immediate interface feedback to
              confirmation or rollback. Uhura owns the temporary experience
              state; the authority backend decides whether the attempted
              change becomes durable.
            </p>
          </div>
          <ExperienceTrace />
        </div>
      </div>
    </section>

    <section class="bg-canvas" aria-labelledby="cycle-title">
      <div class="mx-auto max-w-[1280px] border-x border-t border-line px-6 py-20 sm:px-10 sm:py-24 lg:px-16 lg:py-28">
        <div class="grid gap-10 lg:grid-cols-[0.88fr_1.12fr] lg:items-end">
          <div>
            <p
              class="mb-5 font-mono text-[0.68rem] font-semibold tracking-[0.08em] text-accent"
            >
              what survives
            </p>
            <h2
              id="cycle-title"
              class="max-w-3xl font-sans text-[clamp(2.8rem,5.2vw,5.2rem)] font-medium leading-[0.94] tracking-[-0.065em] text-ink"
            >
              The prototype is temporary. The decisions survive.
            </h2>
          </div>
          <p class="max-w-2xl text-lg leading-8 text-muted lg:justify-self-end">
            Use Spock to resolve the product’s data, rules, states, and
            boundaries while change is cheap. Then carry the checked contracts
            forward as the production specification—not as infrastructure you
            have to deploy.
          </p>
        </div>

        <div class="cycle-track mt-14" aria-label="Spock in the development cycle">
          <div class="cycle-stage">
            <span>before</span>
            <strong>Product questions</strong>
          </div>
          <div class="cycle-arrow" aria-hidden="true">→</div>
          <div class="cycle-stage cycle-stage-active">
            <span>spock</span>
            <strong>Running product contract</strong>
          </div>
          <div class="cycle-arrow" aria-hidden="true">→</div>
          <div class="cycle-stage">
            <span>after</span>
            <strong>Production implementation</strong>
          </div>
        </div>

        <div class="mt-8 grid overflow-hidden rounded-xl border border-line bg-paper md:grid-cols-3">
          {
            roles.map((role, index) => (
              <article
                class:list={[
                  'min-h-48 p-7 sm:p-8',
                  index < roles.length - 1 && 'border-b border-line md:border-b-0 md:border-r',
                ]}
              >
                <h3 class="text-xl font-semibold tracking-[-0.035em] text-ink">{role.title}</h3>
                <p class="mt-4 text-sm leading-7 text-muted">{role.copy}</p>
              </article>
            ))
          }
        </div>

        <p class="mt-8 max-w-3xl text-sm leading-7 text-muted">
          Spock is a local prototype runtime, not a production platform. Keep
          the checked contracts; replace the runtime.
        </p>
      </div>
    </section>
  </main>
</MarketingLayout>

<script>
  document.querySelectorAll<HTMLElement>('[data-hero-audience]').forEach((audience) => {
    const tabs = Array.from(
      audience.querySelectorAll<HTMLButtonElement>('[data-audience-tab]'),
    );
    const commandPanels = Array.from(
      audience.querySelectorAll<HTMLElement>('[data-audience-command]'),
    );
    const copyPanels = Array.from(
      audience.querySelectorAll<HTMLElement>('[data-audience-copy]'),
    );
    const copyButton = audience.querySelector<HTMLButtonElement>('[data-copy-command]');

    const activateAudience = (name: string, focus = false) => {
      audience.dataset.activeAudience = name;

      tabs.forEach((tab) => {
        const active = tab.dataset.audienceTab === name;
        tab.setAttribute('aria-selected', String(active));
        tab.tabIndex = active ? 0 : -1;
        if (active && focus) tab.focus();
      });

      commandPanels.forEach((panel) => {
        const active = panel.dataset.audienceCommand === name;
        panel.hidden = !active;
        if (active && panel.dataset.command && copyButton) {
          copyButton.dataset.copyCommand = panel.dataset.command;
        }
      });

      copyPanels.forEach((panel) => {
        const active = panel.dataset.audienceCopy === name;
        panel.setAttribute('aria-hidden', String(!active));
      });
    };

    tabs.forEach((tab, index) => {
      tab.addEventListener('click', () => {
        if (tab.dataset.audienceTab) activateAudience(tab.dataset.audienceTab);
      });

      tab.addEventListener('keydown', (event) => {
        let nextIndex: number | undefined;

        if (event.key === 'ArrowRight') nextIndex = (index + 1) % tabs.length;
        if (event.key === 'ArrowLeft') nextIndex = (index - 1 + tabs.length) % tabs.length;
        if (event.key === 'Home') nextIndex = 0;
        if (event.key === 'End') nextIndex = tabs.length - 1;
        if (nextIndex === undefined) return;

        event.preventDefault();
        const nextAudience = tabs[nextIndex]?.dataset.audienceTab;
        if (nextAudience) activateAudience(nextAudience, true);
      });
    });
  });

  const copyButton = document.querySelector<HTMLButtonElement>('[data-copy-command]');
  const copyStatus = document.querySelector<HTMLElement>('[data-copy-status]');

  copyButton?.addEventListener('click', async () => {
    const command = copyButton.dataset.copyCommand;
    if (!command) return;

    try {
      await navigator.clipboard.writeText(command);
      copyButton.dataset.copied = 'true';
      copyButton.setAttribute('aria-label', 'Setup command copied');
      if (copyStatus) copyStatus.textContent = 'Setup command copied.';

      window.setTimeout(() => {
        delete copyButton.dataset.copied;
        copyButton.setAttribute('aria-label', 'Copy setup command');
        if (copyStatus) copyStatus.textContent = '';
      }, 1800);
    } catch {
      if (copyStatus) copyStatus.textContent = 'Could not copy the setup command.';
    }
  });
</script>
