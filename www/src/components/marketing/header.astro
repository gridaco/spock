<header class="border-b border-line bg-paper">
  <div
    class="mx-auto flex min-h-18 max-w-[1280px] items-center border-x border-line px-5 sm:px-7 lg:px-10"
  >
    <a
      class="inline-flex shrink-0 items-center gap-2.5 font-sans text-[1.05rem] font-semibold tracking-[-0.03em] text-ink outline-none transition-colors hover:text-accent focus-visible:rounded-sm focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-4 focus-visible:ring-offset-paper"
      href="/"
      aria-label="Spock home"
    >
      <span class="text-[1.15rem]" aria-hidden="true">🖖</span>
      <span>spock</span>
    </a>
    <div
      class="ml-2 hidden -rotate-2 items-center text-accent sm:flex"
      aria-label="It’s only logical !"
    >
      <span class="scribble-note whitespace-nowrap text-[0.72rem] font-semibold"
